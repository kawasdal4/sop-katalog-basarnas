{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "remote": {
    "urls": ["https://e-katalog-sop.cloud/*"]
  },
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:default",
    {
      "identifier": "shell:allow-open",
      "allow": [
        { "schemes": ["http", "https", "mailto", "tel"] },
        { "url": "https://pub-a6302a3a22854799b35a15cd40f9c728.r2.dev/*" },
        { "url": "https://*.sharepoint.com/*" },
        { "url": "https://*.onedrive.live.com/*" },
        { "url": "https://*.office.com/*" }
      ]
    },
    "notification:default",
    "clipboard-manager:default",
    "sql:default",
    "log:default",
    "dialog:default",
    "fs:default",
    "app:allow-get-temp-dir",
    "app:allow-save-temp-file",
    "app:allow-native-open"
  ]
}



