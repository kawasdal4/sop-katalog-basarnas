{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "remote": {
    "urls": ["https://e-katalog-sop.cloud/*"]
  },
  "windows": ["main"],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "shell:default",
    "shell:allow-open",
    "notification:default",
    "clipboard-manager:default",
    "sql:default",
    "log:default",
    "dialog:default",
    "fs:default"
  ]
}
