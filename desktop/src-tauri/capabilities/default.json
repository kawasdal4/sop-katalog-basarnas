{
  "$schema": "../gen/schemas/capability.json",
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "path:default",
    "event:default",
    "window:default",
    "app:default",
    "resources:default",
    "menu:default",
    "tray:default",
    "shell:default",
    "shell:allow-open",
    "notification:default",
    "clipboard-manager:default",
    "sql:default"
  ]
}
