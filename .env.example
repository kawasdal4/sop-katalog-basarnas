# ============================================
# Database Configuration
# ============================================

# Production (PostgreSQL - Supabase/Vercel)
DATABASE_URL="postgresql://user:password@host:6543/database?pgbouncer=true"
DIRECT_DATABASE_URL="postgresql://user:password@host:5432/database"

# Local Development (SQLite)
# DATABASE_URL="file:./dev.db"

# ============================================
# Azure AD / Microsoft 365 (Required for Excel editing)
# ============================================
AZURE_TENANT_ID="your-tenant-id"
AZURE_CLIENT_ID="your-client-id"
AZURE_CLIENT_SECRET="your-client-secret"
M365_SERVICE_ACCOUNT="your-service-account@domain.onmicrosoft.com"

# ============================================
# Google Drive (Backup Storage)
# ============================================
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REFRESH_TOKEN="your-refresh-token"
GOOGLE_DRIVE_FOLDER_ID="your-folder-id"

# ============================================
# Cloudflare R2 (Primary Storage)
# ============================================
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="your-bucket-name"
