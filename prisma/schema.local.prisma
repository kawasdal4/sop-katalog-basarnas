// Local Development Schema - SQLite
// Use this for local development only
// To use: cp prisma/schema.local.prisma prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model with role-based access
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("STAF") // ADMIN or STAF
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastLoginAt DateTime? // Last login timestamp
  
  // Relations
  logs          Log[]
  sopFiles      SopFile[]
  sopPembuatan  SopPembuatan[]
}

// SOP/IK File model
model SopFile {
  id           String   @id @default(cuid())
  nomorSop     String   @unique // SOP-0001, IK-0001, etc
  judul        String
  tahun        Int
  kategori     String   // SIAGA, LATIHAN, LAINNYA
  jenis        String   // SOP or IK
  status       String   @default("AKTIF") // AKTIF, REVIEW, KADALUARSA
  
  // File info
  fileName     String
  filePath     String
  fileType     String   // xlsx or pdf
  driveFileId  String?  // Google Drive file ID
  
  // PDF Preview
  pdfPreviewPath       String?
  pdfPreviewDriveId    String?
  pdfPreviewGeneratedAt DateTime?
  
  // Statistics
  previewCount  Int @default(0)
  downloadCount Int @default(0)
  currentVersion Int @default(1)
  
  // Upload info
  uploadedBy   String
  uploadedAt   DateTime @default(now())
  
  // For public submissions
  isPublicSubmission Boolean   @default(false)
  submitterName      String?
  submitterEmail     String?
  keterangan         String?  // Keterangan/catatan dari pengaju
  verificationStatus String?   @default("MENUNGGU") // MENUNGGU, DISETUJUI, DITOLAK
  verifiedBy         String?
  verifiedAt         DateTime?
  rejectionReason    String?  // Alasan penolakan
  arsipFolder        String?  // Folder di arsip (e.g., 'Publik-Ditolak')
  
  // Relations
  user     User     @relation(fields: [uploadedBy], references: [id])
  logs     Log[]
  
  updatedAt DateTime @updatedAt
}

// Activity Log model
model Log {
  id          String   @id @default(cuid())
  userId      String
  aktivitas   String   // UPLOAD, DOWNLOAD, PREVIEW, EDIT_STATUS, VERIFIKASI, LOGIN
  deskripsi   String
  fileId      String?
  metadata    String?  // JSON string for additional data
  createdAt   DateTime @default(now())
  
  // Relations
  user    User     @relation(fields: [userId], references: [id])
  sopFile SopFile? @relation(fields: [fileId], references: [id])
}

// Counter for auto-generate nomor SOP
model Counter {
  id        String @id @default("counter")
  sopCount  Int    @default(0)
  ikCount   Int    @default(0)
}

// File Sync model for tracking sync between Drive and R2
model FileSync {
  id              String   @id @default(cuid())
  filename        String
  mimeType        String
  fileSize        Int
  driveFileId     String?  @unique
  r2Key           String?  @unique
  checksum        String?
  source          String   @default("drive") // drive, r2, both
  syncStatus      String   @default("pending") // pending, synced, error, conflict
  lastError       String?
  driveModifiedAt DateTime?
  r2ModifiedAt    DateTime?
  lastSyncedAt    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Sync Log model for tracking sync operations
model SyncLog {
  id        String   @id @default(cuid())
  operation String   // migrate, sync, backup
  filename  String
  status    String   // success, error
  message   String?
  details   String?  // JSON string for additional data
  createdAt DateTime @default(now())
}

// File Edit Session model for desktop Excel editing
model FileEditSession {
  id            String   @id @default(cuid())
  objectKey     String   // R2 object key
  sopFileId     String?  // Link to SOP file
  editorUserId  String
  editorEmail   String
  editorName    String?
  originalHash  String   // Hash of file when edit started
  lockedAt      DateTime @default(now())
  expiresAt     DateTime
  status        String   @default("active") // active, completed, expired
  lastSyncedAt  DateTime?
  completedAt   DateTime?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// File Edit Log model for tracking edit actions
model FileEditLog {
  id           String   @id @default(cuid())
  objectKey    String
  editorUserId String
  editorEmail  String
  editorName   String?
  action       String   // started, synced, expired, force_overwrite, cancelled
  sessionId    String?
  details      String?  // JSON string for additional data
  timestamp    DateTime @default(now())
}

// File Print Cache model for caching converted PDFs
model FilePrintCache {
  id              String   @id @default(cuid())
  sopFileId       String   @unique // Link to SOP file
  r2LastModified  DateTime // Last modified time of source Excel
  fileHash        String   // SHA-256 hash of source Excel
  cachedPdfPath   String   // R2 path for cached PDF
  cachedPdfSize   Int      // PDF file size in bytes
  conversionTime  Int      // Time taken for conversion in ms
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@index([sopFileId])
  @@index([fileHash])
}

// ---------------------------------------------------------------------------
// FITUR PEMBUATAN SOP TERINTEGRASI
// ---------------------------------------------------------------------------

model SopPembuatan {
  id                    String   @id @default(cuid())
  nomorSop              String?  @unique
  judul                 String
  unitKerja             String
  tanggalEfektif        DateTime?
  revisi                String?
  dasarHukum            String?
  kualifikasiPelaksana  String?
  peralatanPerlengkapan String?
  peringatan            String?
  pencatatanPendataan   String?
  keterkaitan           String?
  disahkanOleh          String?
  pelaksanaLanes        String?
  connectorPaths        String?
  status                String   @default("DRAFT") // DRAFT, FINAL
  
  // File results
  generatedCoverPath    String?
  combinedPdfPath       String?

  authorId              String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relasi
  author                User         @relation(fields: [authorId], references: [id])
  langkahLangkah        SopLangkah[]
}

model SopLangkah {
  id                  String   @id @default(cuid())
  order               Int
  aktivitas           String
  pelaksana           String   // JSON string array eg: "['Pelapor', 'Kagahar']"
  stepType            String?  @default("process") // start, process, decision, document, end
  nextStepYes         Int?
  nextStepNo          Int?
  mutuBakuKelengkapan String?
  mutuBakuWaktu       String?
  mutuBakuOutput      String?
  keterangan          String?

  sopPembuatanId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relasi
  sopPembuatan        SopPembuatan @relation(fields: [sopPembuatanId], references: [id], onDelete: Cascade)
}

